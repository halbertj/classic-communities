# ---------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------
# Find these under: Supabase Dashboard → Project Settings → API
# Copy this file to `.env.local` and fill in real values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key

# ---------------------------------------------------------------
# Supabase CLI (optional, only needed for `npm run types:generate`)
# ---------------------------------------------------------------
# Your project's ref (the subdomain in NEXT_PUBLIC_SUPABASE_URL).
SUPABASE_PROJECT_ID=your-project-ref

# ---------------------------------------------------------------
# Server-side only — NEVER ship this to the client.
# ---------------------------------------------------------------
# Required for `npm run import:communities` (bypasses RLS to bulk-load data).
# Dashboard → Project Settings → API Keys → "secret" (starts with sb_secret_…).
# The legacy "service_role" JWT also works for backwards compat.
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# ---------------------------------------------------------------
# Mapbox
# ---------------------------------------------------------------
# Public token used for both the seed script (server-side geocoding) and
# eventually address autocomplete in the admin UI. URL-restrict this token to
# your dev/prod domains in the Mapbox dashboard; the seed script spoofs a
# matching Referer header so it can still call through.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token
